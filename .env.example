# Copy to .env for local development, or set these in Railway project variables.

# Port (Railway sets this automatically; default 3000 locally)
PORT=3000

# Database file path. On Railway, mount a volume at /app/data and set:
#   DB_PATH=/app/data/app.db
# Leaving it unset defaults to ./data/app.db relative to the repo root.
# DB_PATH=/app/data/app.db

# Initial admin credentials. If set, the server creates this admin on boot (once).
# If unset AND no admin exists yet, a default admin is created with warning logs.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator
